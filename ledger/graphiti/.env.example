# Graphiti Memory System — Environment Variables
# Copy this to .env and fill in your keys:
#   cp .env.example .env

# OpenRouter API key (required)
# Used for both LLM (entity extraction via Haiku) and embeddings (text-embedding-3-small)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic API key (optional — only needed if using Anthropic directly)
ANTHROPIC_API_KEY=

# Neo4j credentials (defaults are fine for local Docker setup)
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphiti-memory-2026
NEO4J_DATABASE=neo4j
